# ── Backend ──────────────────────────────────────────────────────────────────
# Copy to .env and fill in real values. Never commit .env to git.

NODE_ENV=development

# Database (matches docker-compose.yml defaults for local dev)
DATABASE_URL=postgresql://onesell:onesell_dev_pw@localhost:5432/onesell_dev

# Redis (matches docker-compose.yml defaults for local dev)
REDIS_URL=redis://localhost:6379

# JWT — generate with: node -e "require('crypto').generateKeyPairSync('rsa',{modulusLength:2048}).privateKey"
# In production, load from AWS Secrets Manager
JWT_PRIVATE_KEY=<RS256 private key — PEM format>
JWT_PUBLIC_KEY=<RS256 public key — PEM format>

# LLM API keys (never commit real keys)
OPENAI_API_KEY=sk-...
QWEN_API_KEY=<Qwen API key for CN market>
DEEPSEEK_API_KEY=<DeepSeek API key — CN market alternative>

# Exchange rate API (used by calc-margin tool)
EXCHANGE_RATE_API_KEY=<exchange rate API key>

# App
PORT=3001
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173

# ── Client (Electron / Vite) ──────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3001/api/v1
