{
  "name": "onesell-client",
  "version": "2.1.2",
  "private": true,
  "description": "OneSell Scout — Electron Desktop Client",
  "author": "OneSell Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/chenning007/OneSell.git"
  },
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.main.json && vite build",
    "build:ci": "tsc -p tsconfig.main.json && vite build --mode production",
    "preview": "vite preview",
    "electron:dev": "concurrently \"pnpm dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:start": "cross-env NODE_ENV=production node node_modules/electron/cli.js .",
    "electron:build": "pnpm build && electron-builder",
    "lint": "eslint 'src/**/*.ts' 'src/**/*.tsx'",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json",
    "test:unit": "vitest run tests/unit"
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "electron-updater": "^6.3.0",
    "i18next": "^25.8.18",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-i18next": "^16.5.8",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.0",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^2.1.0",
    "concurrently": "^9.0.0",
    "cross-env": "^10.1.0",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.2",
    "vitest": "^2.1.0",
    "wait-on": "^8.0.0"
  }
}
